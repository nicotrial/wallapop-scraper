# Wallapop Project Car Search Tool Configuration
# Copy this file to .env and fill in your values

# Default search location (optional)
# Example: Madrid, Spain
DEFAULT_LATITUDE=40.4168
DEFAULT_LONGITUDE=-3.7038
DEFAULT_RADIUS=50

# Default price range (optional)
DEFAULT_MIN_PRICE=500
DEFAULT_MAX_PRICE=5000

# Request delay in seconds (to avoid rate limiting)
REQUEST_DELAY=2.0
